# ============================================================
# OpenClaw Docker 部署 - 环境变量配置
# 复制此文件为 .env 并修改相应的值
# ============================================================

# Docker 镜像配置
OPENCLAW_IMAGE=justlikemaki/openclaw-docker-cn-im:latest

# ============================================================
# 模型配置（必填）
# ============================================================
# 是否自动同步模型配置到 openclaw.json
SYNC_MODEL_CONFIG=true

# 提供商 1（默认）
MODEL_ID=claude-sonnet-4-5-20250514
IMAGE_MODEL_ID=
BASE_URL=https://api.anthropic.com
API_KEY=your-api-key-here
# 协议类型: openai-completions 或 anthropic-messages
API_PROTOCOL=anthropic-messages
CONTEXT_WINDOW=200000
MAX_TOKENS=8192

# 提供商 2（可选，取消注释启用）
# MODEL2_NAME=openai
# MODEL2_MODEL_ID=gpt-4o
# MODEL2_BASE_URL=https://api.openai.com/v1
# MODEL2_API_KEY=your-openai-key
# MODEL2_PROTOCOL=openai-completions
# MODEL2_CONTEXT_WINDOW=128000
# MODEL2_MAX_TOKENS=4096

# ============================================================
# 渠道通用配置
# ============================================================
# 私聊策略: open/closed/friend-only
DM_POLICY=open
# 群组策略: open/closed
GROUP_POLICY=open
# 允许来源（* 代表全部，多个用逗号隔开）
ALLOW_FROM=*

# ============================================================
# IM 平台配置（按需启用，留空则不启用）
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- 飞书 ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_STREAMING=true
FEISHU_FOOTER_ELAPSED=true
FEISHU_FOOTER_STATUS=true
FEISHU_REQUIRE_MENTION=true
# 是否启用飞书官方插件（与旧版 feishu 渠道互斥）
FEISHU_OFFICIAL_PLUGIN_ENABLED=false

# --- 钉钉 ---
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_CORP_ID=
DINGTALK_AGENT_ID=

# --- QQ 机器人（官方 API）---
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=

# --- QQ 机器人（NapCat/OneBot v11）---
NAPCAT_REVERSE_WS_PORT=
NAPCAT_HTTP_URL=
NAPCAT_ACCESS_TOKEN=
NAPCAT_ADMINS=

# --- 企业微信 ---
# 方式1：单账号
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
# 方式2：多账号 JSON（单行）
WECOM_BOTS_JSON=

# ============================================================
# 工作空间与数据目录
# ============================================================
WORKSPACE=/home/node/.openclaw/workspace
# 数据目录（Linux/Mac 用 ~/.openclaw，Windows 用 %USERPROFILE%\.openclaw）
OPENCLAW_DATA_DIR=~/.openclaw
# 容器启动用户（默认 root，自动降权）
OPENCLAW_RUN_USER=0:0

# ============================================================
# Gateway 配置
# ============================================================
OPENCLAW_GATEWAY_TOKEN=changeme-use-a-strong-token
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_MODE=local
OPENCLAW_GATEWAY_ALLOWED_ORIGINS=http://localhost,http://localhost:18789,http://127.0.0.1,http://127.0.0.1:18789
OPENCLAW_GATEWAY_ALLOW_INSECURE_AUTH=true
OPENCLAW_GATEWAY_DANGEROUSLY_DISABLE_DEVICE_AUTH=true
OPENCLAW_GATEWAY_AUTH_MODE=
OPENCLAW_PLUGINS_ENABLED=true
